// wap to check string rotation 

#include <stdio.h>
#include <string.h>

#define MAX_SIZE 100

int main() {
    char str1[MAX_SIZE];
    char str2[MAX_SIZE];
    
    char temp[MAX_SIZE * 2]; 

    printf("Enter the first string: ");
    if (fgets(str1, sizeof(str1), stdin) == NULL) {
        printf("Error: Failed to read input stream.\n");
        return 1;
    }

    printf("Enter the second string: ");
    if (fgets(str2, sizeof(str2), stdin) == NULL) {
        printf("Error: Failed to read input stream.\n");
        return 1;
    }

    int len1 = 0;
    while (str1[len1] != '\0') len1++;
    if (len1 > 0 && str1[len1 - 1] == '\n') {
        len1--;
        str1[len1] = '\0';
    }

    int len2 = 0;
    while (str2[len2] != '\0') len2++;
    if (len2 > 0 && str2[len2 - 1] == '\n') {
        len2--;
        str2[len2] = '\0';
    }

    if (len1 != len2) {
        printf("\nResult: The strings are NOT rotations (Length mismatch).\n");
        return 0;
    }

    if (len1 == 0) {
        printf("\nResult: The strings are valid rotations.\n");
        return 0;
    }

    strcpy(temp, str1);
    strcat(temp, str1);

    if (strstr(temp, str2) != NULL) {
        printf("\nResult: \"%s\" is a valid rotation of \"%s\".\n", str2, str1);
    } else {
        printf("\nResult: \"%s\" is NOT a rotation of \"%s\".\n", str2, str1);
    }

    return 0;
}