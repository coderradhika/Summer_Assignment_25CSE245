// wap to union of arrays

#include <stdio.h>

#define MAX_SIZE 50
#define UNION_MAX (MAX_SIZE * 2)

int isPresent(int arr[], int size, int value) {
    for (int i = 0; i < size; i++) {
        if (arr[i] == value) {
            return 1; 
        }
    }
    return 0; 
}

int main() {
    int arr1[MAX_SIZE], arr2[MAX_SIZE];
    int unionArr[UNION_MAX];
    int n1, n2, unionSize = 0;

    printf("Enter the number of elements for Array 1 (1 to %d): ", MAX_SIZE);
    if (scanf("%d", &n1) != 1 || n1 <= 0 || n1 > MAX_SIZE) {
        printf("Error: Invalid size for Array 1.\n");
        return 1;
    }

    printf("Enter %d integers for Array 1:\n", n1);
    for (int i = 0; i < n1; i++) {
        printf("Array1 [%d]: ", i);
        if (scanf("%d", &arr1[i]) != 1) {
            printf("Error: Invalid input.\n");
            return 1;
        }
    }

    printf("Enter the number of elements for Array 2 (1 to %d): ", MAX_SIZE);
    if (scanf("%d", &n2) != 1 || n2 <= 0 || n2 > MAX_SIZE) {
        printf("Error: Invalid size for Array 2.\n");
        return 1;
    }

    printf("Enter %d integers for Array 2:\n", n2);
    for (int i = 0; i < n2; i++) {
        printf("Array2 [%d]: ", i);
        if (scanf("%d", &arr2[i]) != 1) {
            printf("Error: Invalid input.\n");
            return 1;
        }
    }

    for (int i = 0; i < n1; i++) {
        if (!isPresent(unionArr, unionSize, arr1[i])) {
            unionArr[unionSize] = arr1[i];
            unionSize++;
        }
    }

    for (int i = 0; i < n2; i++) {
        if (!isPresent(unionArr, unionSize, arr2[i])) {
            unionArr[unionSize] = arr2[i];
            unionSize++;
        }
    }

    printf("\nUnion of the two arrays (Total Unique Elements: %d):\n", unionSize);
    for (int i = 0; i < unionSize; i++) {
        printf("%d ", unionArr[i]);
    }
    printf("\n");

    return 0;
}