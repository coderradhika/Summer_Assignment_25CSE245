// wap to find common elements 

#include <stdio.h>

#define MAX_SIZE 50

int isPresent(int arr[], int size, int value) {
    for (int i = 0; i < size; i++) {
        if (arr[i] == value) {
            return 1; 
        }
    }
    return 0; 
}

int main() {
    int arr1[MAX_SIZE], arr2[MAX_SIZE];
    int commonArr[MAX_SIZE]; 
    int n1, n2, commonCount = 0;
    printf("Enter the number of elements for Array 1 (1 to %d): ", MAX_SIZE);
    if (scanf("%d", &n1) != 1 || n1 <= 0 || n1 > MAX_SIZE) {
        printf("Error: Invalid size for Array 1.\n");
        return 1;
    }

    printf("Enter %d integers for Array 1:\n", n1);
    for (int i = 0; i < n1; i++) {
        printf("Array1 [%d]: ", i);
        if (scanf("%d", &arr1[i]) != 1) {
            printf("Error: Invalid input. Expected an integer.\n");
            return 1;
        }
    }

    printf("Enter the number of elements for Array 2 (1 to %d): ", MAX_SIZE);
    if (scanf("%d", &n2) != 1 || n2 <= 0 || n2 > MAX_SIZE) {
        printf("Error: Invalid size for Array 2.\n");
        return 1;
    }

    printf("Enter %d integers for Array 2:\n", n2);
    for (int i = 0; i < n2; i++) {
        printf("Array2 [%d]: ", i);
        if (scanf("%d", &arr2[i]) != 1) {
            printf("Error: Invalid input. Expected an integer.\n");
            return 1;
        }
    }

    for (int i = 0; i < n1; i++) {
        if (isPresent(arr2, n2, arr1[i])) {
            if (!isPresent(commonArr, commonCount, arr1[i])) {
                commonArr[commonCount] = arr1[i];
                commonCount++;
            }
        }
    }

    printf("\n--- Common Elements ---\n");
    if (commonCount == 0) {
        printf("No common elements found between the two arrays.\n");
    } else {
        printf("Found %d unique common element(s):\n", commonCount);
        for (int i = 0; i < commonCount; i++) {
            printf("%d ", commonArr[i]);
        }
        printf("\n");
    }

    return 0;
}