// wap to second largest element

#include <stdio.h>
#include <limits.h> 

#define MAX_SIZE 100

int main() {
    int arr[MAX_SIZE];
    int n;

    printf("Enter the number of elements (2 to %d): ", MAX_SIZE);
    if (scanf("%d", &n) != 1 || n < 2 || n > MAX_SIZE) {
        printf("Error: Invalid size. You need at least 2 elements.\n");
        return 1;
    }

    printf("Enter %d integers:\n", n);
    for (int i = 0; i < n; i++) {
        printf("Element [%d]: ", i);
        if (scanf("%d", &arr[i]) != 1) {
            printf("Error: Invalid input. Expected an integer.\n");
            return 1;
        }
    }

    int max = INT_MIN;
    int secondMax = INT_MIN;

    for (int i = 0; i < n; i++) {
        if (arr[i] > max) {
            secondMax = max;
            max = arr[i];
        } 
        else if (arr[i] > secondMax && arr[i] != max) {
            secondMax = arr[i];
        }
    }

    printf("\n--- Results ---\n");
    if (secondMax == INT_MIN) {
        printf("Error: No second largest element exists (all unique values are identical).\n");
    } else {
        printf("Largest Element        = %d\n", max);
        printf("Second Largest Element = %d\n", secondMax);
    }

    return 0;
}