// wap to find duplicate in array

#include <stdio.h>

#define MAX_SIZE 100

int main() {
    int arr[MAX_SIZE];
    int visited[MAX_SIZE] = {0}; 
    int n;
    int hasDuplicates = 0;

    printf("Enter the number of elements (1 to %d): ", MAX_SIZE);
    if (scanf("%d", &n) != 1 || n <= 0 || n > MAX_SIZE) {
        printf("Error: Invalid size. Must be between 1 and %d.\n", MAX_SIZE);
        return 1;
    }

    printf("Enter %d integers:\n", n);
    for (int i = 0; i < n; i++) {
        printf("Element [%d]: ", i);
        if (scanf("%d", &arr[i]) != 1) {
            printf("Error: Invalid input. Expected an integer.\n");
            return 1;
        }
    }

    printf("\n--- Duplicate Elements ---\n");
    for (int i = 0; i < n; i++) {
        if (visited[i] == 1) {
            continue;
        }

        int isDuplicate = 0;
        for (int j = i + 1; j < n; j++) {
            if (arr[i] == arr[j]) {
                isDuplicate = 1;
                visited[j] = 1; 
            }
        }

        if (isDuplicate) {
            printf("%d is duplicated\n", arr[i]);
            hasDuplicates = 1;
        }
    }

    if (!hasDuplicates) {
        printf("No duplicate elements found.\n");
    }

    return 0;
}