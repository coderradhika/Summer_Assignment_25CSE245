#include <stdio.h>

unsigned long long getFibonacci(int n) {
    if (n == 0) return 0;
    if (n == 1) return 1;

    unsigned long long a = 0;
    unsigned long long b = 1;
    unsigned long long next;

    for (int i = 2; i <= n; i++) {
        next = a + b;
        a = b;
        b = next;
    }

    return b;
}

int main() {
    int n;

    printf("Enter the Fibonacci term position (n): ");
    scanf("%d", &n);

    if (n < 0) {
        printf("Error: Position cannot be negative.\n");
    } 
    else if (n > 93) {
        printf("Error: Value too large. Term 94 and above will overflow 64-bit integer limits.\n");
    } 
    else {
        unsigned long long result = getFibonacci(n);
        printf("Fibonacci term at position %d is: %llu\n", n, result);
    }

    return 0;
}