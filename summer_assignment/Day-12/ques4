// wap to write function for perfect no. 

#include <stdio.h>

int isPerfect(long long n) {
    if (n <= 1) {
        return 0;
    }

    long long sum = 1; 

    for (long long i = 2; i * i <= n; i++) {
        if (n % i == 0) {
            sum += i;
            
            if (i * i != n) {
                sum += n / i;
            }
        }
    }

    return (sum == n);
}

int main() {
    long long num;

    printf("Enter an integer: ");
    scanf("%lld", &num);

    if (isPerfect(num)) {
        printf("%lld is a perfect number.\n", num);
    } else {
        printf("%lld is not a perfect number.\n", num);
    }

    return 0;
}