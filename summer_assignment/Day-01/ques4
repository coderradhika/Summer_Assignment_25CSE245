// wap to count digits in a no.

#include <stdio.h>

int main()
{
    long long n;
    int count = 0;

    printf("Enter an integer: ");
    scanf("%lld", &n);

    do
    {
        n /= 10;
        count++;
    } while (n != 0);

    printf("Total number of digits: %d\n", count);

    return 0;
}
