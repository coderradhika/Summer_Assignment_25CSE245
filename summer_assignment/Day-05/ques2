// wap to check strong no. 

#include <stdio.h>

int main() {
    int n, originalN, remainder, sum = 0, fact, i;

    printf("Enter a positive integer: ");
    scanf("%d", &n);

    originalN = n;

    if (n <= 0) {
        printf("%d is NOT a strong number.\n", originalN);
    } 
    else {
        while (n != 0) {
            remainder = n % 10; 
            fact = 1;
            for(i = 1; i <= remainder; i++) {
                fact *= i;
            }
            
            sum += fact;
            n /= 10;
        }

        if (sum == originalN) {
            printf("%d is a strong number.\n", originalN);
        } 
        else {
            printf("%d is NOT a strong number.\n", originalN);
        }
    }

    return 0;
}
