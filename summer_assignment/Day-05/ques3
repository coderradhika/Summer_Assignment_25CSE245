//wap to print factors of a no. 

#include <stdio.h>

int main() {
    int n, i;

    printf("Enter a positive integer: ");
    scanf("%d", &n);

    if (n <= 1) {
        printf("Prime factorization is not applicable for numbers less than or equal to 1.\n");
    } 
    else {
        printf("Prime factors of %d are: ", n);

        while (n % 2 == 0) {
            printf("%d ", 2);
            n /= 2;
        }

        for (i = 3; i * i <= n; i += 2) {
            while (n % i == 0) {
                printf("%d ", i);
                n /= i;
            }
        }

        if (n > 2) {
            printf("%d ", n);
        }
        
        printf("\n");
    }

    return 0;
}