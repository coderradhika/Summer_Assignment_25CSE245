// wap to find the product of digits

#include <stdio.h>

int main() {
    long long n, product = 1;
    int digit;

    printf("Enter an integer: ");
    scanf("%lld", &n);

    if (n == 0) {
        product = 0;
    } 
    else {
        
        if (n < 0) {
            n = -n;
        }

        while (n != 0) {
            digit = n % 10;     
            product *= digit;   
            n /= 10;            
        }
    }

    printf("Product of the digits: %lld\n", product);

    return 0;
}
