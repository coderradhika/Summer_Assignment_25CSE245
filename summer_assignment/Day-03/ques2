// wap to print prime no. in a range

#include <stdio.h>

int main() {
    int start, end, i, j, isPrime;

    printf("Enter the lower bound: ");
    scanf("%d", &start);
    printf("Enter the upper bound: ");
    scanf("%d", &end);

    printf("\nPrime numbers between %d and %d are:\n", start, end);
    printf("----------------------------------------\n");

    for (i = start; i <= end; ++i) {
        
        if (i <= 1) {
            continue; 
        }

        isPrime = 1; 

        for (j = 2; j * j <= i; ++j) {
            if (i % j == 0) {
                isPrime = 0; 
                break;       
            }
        }

        if (isPrime == 1) {
            printf("%d ", i);
        }
    }
    
    printf("\n"); 

    return 0;
}