// wap to recursive factorial 

#include <stdio.h>

unsigned long long factorial(int n) {
    if (n == 0 || n == 1) {
        return 1;
    }
    
    return n * factorial(n - 1);
}

int main() {
    int n;

    printf("Enter a positive integer: ");
    scanf("%d", &n);

    if (n < 0) {
        printf("Error: Factorial of a negative number doesn't exist.\n");
    } 
    else if (n > 20) {
        printf("Error: Value too large. This program can only compute up to 20!\n");
    } 
    else {
        printf("Factorial of %d using recursion is: %llu\n", n, factorial(n));
    }

    return 0;
}