// wap to binary search 

#include <stdio.h>

#define MAX_SIZE 100

int main() {
    int arr[MAX_SIZE];
    int n, target;
    int foundIndex = -1;

    printf("Enter the number of elements (1 to %d): ", MAX_SIZE);
    if (scanf("%d", &n) != 1 || n <= 0 || n > MAX_SIZE) {
        printf("Error: Invalid size. Must be between 1 and %d.\n", MAX_SIZE);
        return 1;
    }

    printf("Enter %d integers in STRICTLY ASCENDING/SORTED order:\n", n);
    for (int i = 0; i < n; i++) {
        printf("Element [%d]: ", i);
        if (scanf("%d", &arr[i]) != 1) {
            printf("Error: Invalid input. Expected an integer.\n");
            return 1;
        }
        if (i > 0 && arr[i] < arr[i - 1]) {
            printf("Error: Dataset is not sorted. Binary search will fail.\n");
            return 1;
        }
    }

    printf("Enter the element to search for: ");
    if (scanf("%d", &target) != 1) {
        printf("Error: Invalid target input.\n");
        return 1;
    }

    int low = 0;
    int high = n - 1;

    while (low <= high) {
        int mid = low + (high - low) / 2;

        if (arr[mid] == target) {
            foundIndex = mid;
            break;
        } 
        else if (arr[mid] < target) {
            low = mid + 1; 
        } 
        else {
            high = mid - 1; 
        }
    }

    if (foundIndex != -1) {
        printf("\nSuccess: Element %d found at index position: %d\n", target, foundIndex);
    } else {
        printf("\nElement %d not found in the array.\n", target);
    }

    return 0;
}