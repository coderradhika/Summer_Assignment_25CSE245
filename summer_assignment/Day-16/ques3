// wap to find pair with given sum 

#include <stdio.h>

#define MAX_SIZE 100

int main() {
    int arr[MAX_SIZE];
    int n, targetSum;
    int pairFound = 0;

    printf("Enter the number of elements (2 to %d): ", MAX_SIZE);
    if (scanf("%d", &n) != 1 || n < 2 || n > MAX_SIZE) {
        printf("Error: Invalid size. You need at least 2 elements.\n");
        return 1;
    }

    printf("Enter %d integers:\n", n);
    for (int i = 0; i < n; i++) {
        printf("Element [%d]: ", i);
        if (scanf("%d", &arr[i]) != 1) {
            printf("Error: Invalid input. Expected an integer.\n");
            return 1;
        }
    }

    printf("Enter the target sum to find: ");
    if (scanf("%d", &targetSum) != 1) {
        printf("Error: Invalid target sum input.\n");
        return 1;
    }

    printf("\n--- Matching Pairs ---\n");
    for (int i = 0; i < n - 1; i++) {
        for (int j = i + 1; j < n; j++) {
            if (arr[i] + arr[j] == targetSum) {
                printf("(%d, %d) found at indices [%d] and [%d]\n", arr[i], arr[j], i, j);
                pairFound = 1;
            }
        }
    }

    if (!pairFound) {
        printf("No pair exists in the array that adds up to %d.\n", targetSum);
    }

    return 0;
}