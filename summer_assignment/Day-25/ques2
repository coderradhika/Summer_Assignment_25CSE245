// wap to find common characters in strings 

#include <stdio.h>

#define MAX_SIZE 256

int main() {
    char str1[MAX_SIZE];
    char str2[MAX_SIZE];
    
    int lookup[256] = {0}; 
    int hasCommon = 0;

    printf("Enter the first string: ");
    if (fgets(str1, sizeof(str1), stdin) == NULL) {
        printf("Error: Failed to read input stream.\n");
        return 1;
    }

    printf("Enter the second string: ");
    if (fgets(str2, sizeof(str2), stdin) == NULL) {
        printf("Error: Failed to read input stream.\n");
        return 1;
    }

    int len1 = 0;
    while (str1[len1] != '\0') len1++;
    if (len1 > 0 && str1[len1 - 1] == '\n') {
        str1[len1 - 1] = '\0';
    }

    int len2 = 0;
    while (str2[len2] != '\0') len2++;
    if (len2 > 0 && str2[len2 - 1] == '\n') {
        str2[len2 - 1] = '\0';
    }

    for (int i = 0; str1[i] != '\0'; i++) {
        unsigned char ch = (unsigned char)str1[i];
        lookup[ch] = 1;
    }

    printf("\n--- Common Distinct Characters ---\n");
    for (int i = 0; str2[i] != '\0'; i++) {
        unsigned char ch = (unsigned char)str2[i];

        if (lookup[ch] == 1) {
            if (ch == ' ') {
                printf("- [Space Character]\n");
            } else {
                printf("- '%c'\n", ch);
            }
            
            lookup[ch] = 2; 
            hasCommon = 1;
        }
    }

    if (!hasCommon) {
        printf("No common characters found between the two strings.\n");
    }

    return 0;
}