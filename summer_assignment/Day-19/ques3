// wap to transpose matrix 

#include <stdio.h>

#define MAX_ROWS 10
#define MAX_COLS 10

int main() {
    int matrix[MAX_ROWS][MAX_COLS];
    int transpose[MAX_COLS][MAX_ROWS]; 
    int r, c;

    printf("Enter rows and columns for the matrix (Max %dx%d): ", MAX_ROWS, MAX_COLS);
    if (scanf("%d %d", &r, &c) != 2 || r <= 0 || r > MAX_ROWS || c <= 0 || c > MAX_COLS) {
        printf("Error: Invalid dimensions. Limits are 1 to %d.\n", MAX_ROWS);
        return 1;
    }

    printf("\nEnter elements for the matrix (%dx%d):\n", r, c);
    for (int i = 0; i < r; i++) {
        for (int j = 0; j < c; j++) {
            printf("Element [%d][%d]: ", i, j);
            if (scanf("%d", &matrix[i][j]) != 1) {
                printf("Error: Invalid integer input.\n");
                return 1;
            }
        }
    }

    for (int i = 0; i < r; i++) {
        for (int j = 0; j < c; j++) {
            transpose[j][i] = matrix[i][j];
        }
    }

    printf("\n--- Original Matrix (%dx%d) ---\n", r, c);
    for (int i = 0; i < r; i++) {
        for (int j = 0; j < c; j++) {
            printf("%d\t", matrix[i][j]);
        }
        printf("\n");
    }

    printf("\n--- Transposed Matrix (%dx%d) ---\n", c, r);
    for (int i = 0; i < c; i++) {
        for (int j = 0; j < r; j++) {
            printf("%d\t", transpose[i][j]);
        }
        printf("\n");
    }

    return 0;
}