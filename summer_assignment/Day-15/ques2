// wap to rotate array left 

#include <stdio.h>

#define MAX_SIZE 100

void reverse(int arr[], int start, int end) {
    while (start < end) {
        int temp = arr[start];
        arr[start] = arr[end];
        arr[end] = temp;
        start++;
        end--;
    }
}

int main() {
    int arr[MAX_SIZE];
    int n, d;

    printf("Enter the number of elements (1 to %d): ", MAX_SIZE);
    if (scanf("%d", &n) != 1 || n <= 0 || n > MAX_SIZE) {
        printf("Error: Invalid size.\n");
        return 1;
    }

    printf("Enter %d integers:\n", n);
    for (int i = 0; i < n; i++) {
        printf("Element [%d]: ", i);
        if (scanf("%d", &arr[i]) != 1) {
            printf("Error: Invalid input.\n");
            return 1;
        }
    }

    printf("Enter the number of positions to left rotate: ");
    if (scanf("%d", &d) != 1 || d < 0) {
        printf("Error: Invalid rotation count.\n");
        return 1;
    }

    d = d % n;

    if (d > 0) {
        reverse(arr, 0, d - 1); 
        reverse(arr, d, n - 1); 
        reverse(arr, 0, n - 1); 
    }

    printf("\nArray after left rotation:\n");
    for (int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }
    printf("\n");

    return 0;
}