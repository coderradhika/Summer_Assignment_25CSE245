// wap to move zeroes to end

#include <stdio.h>

#define MAX_SIZE 100

int main() {
    int arr[MAX_SIZE];
    int n;

    printf("Enter the number of elements (1 to %d): ", MAX_SIZE);
    if (scanf("%d", &n) != 1 || n <= 0 || n > MAX_SIZE) {
        printf("Error: Invalid size. Must be between 1 and %d.\n", MAX_SIZE);
        return 1;
    }

    printf("Enter %d integers:\n", n);
    for (int i = 0; i < n; i++) {
        printf("Element [%d]: ", i);
        if (scanf("%d", &arr[i]) != 1) {
            printf("Error: Invalid integer input.\n");
            return 1;
        }
    }

    int writePtr = 0;

    for (int readPtr = 0; readPtr < n; readPtr++) {
        if (arr[readPtr] != 0) {
            arr[writePtr] = arr[readPtr];
            writePtr++;
        }
    }

    while (writePtr < n) {
        arr[writePtr] = 0;
        writePtr++;
    }

    printf("\nArray after moving zeroes to the end:\n");
    for (int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }
    printf("\n");

    return 0;
}